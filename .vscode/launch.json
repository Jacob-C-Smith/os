{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Kernel Debug",
      "type": "cppdbg",
      "request": "launch",

      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/os",

      "MIMode": "gdb",
      "miDebuggerPath": "/usr/local/bin/gdb",

      "preLaunchTask": "Run QEMU",

      "setupCommands": [
        { "text": "set architecture i386" },
        { "text": "target remote localhost:1234" },
      ]
    }
  ]
}